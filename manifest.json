{
  "manifest_version": 3,
  "name": "Intentional Speed Bump",
  "version": "1.0",
  "description": "Inserts a friction-based choice point before loading YouTube.",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.x.com/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}